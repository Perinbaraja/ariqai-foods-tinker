<script
  type="module"
  src="{{ 'request-quote.js' | asset_url }}"
  fetchpriority="low"
></script>

<request-quote-modal id="request-quote-modal-root">
  <dialog
    class="request-quote-modal dialog-modal color-{{ settings.popover_color_scheme }}"
    id="request-quote-modal"
    aria-labelledby="request-quote-title"
  >
    <div class="request-quote-modal__inner">
      <div class="request-quote-modal__header">
        <div>
          <p class="request-quote-modal__eyebrow">B2B Inquiry</p>
          <h2
            id="request-quote-title"
            class="request-quote-modal__title"
          >
            Request quote
          </h2>
        </div>

        <button
          type="button"
          class="button button-unstyled close-button request-quote-modal__close"
          data-request-quote-close
          aria-label="{{ 'actions.close_dialog' | t }}"
        >
          <span class="svg-wrapper">
            {{- 'icon-close.svg' | inline_asset_content -}}
          </span>
        </button>
      </div>

      <div class="request-quote-modal__body">
        {%- form 'contact', id: 'RequestQuoteForm', class: 'request-quote-form' -%}
          <input
            type="hidden"
            name="contact[quote source]"
            id="RequestQuoteSource"
            value=""
          >
          <input
            type="hidden"
            name="contact[product url]"
            id="RequestQuoteProductUrl"
            value=""
          >

          {%- if form.posted_successfully? -%}
            <div class="request-quote-form__success">
              {{- 'icon-checkmark.svg' | inline_asset_content -}}
              <span>Your quote request has been sent.</span>
            </div>
          {%- endif -%}

          {%- if form.errors -%}
            <div
              class="request-quote-form__error"
              tabindex="-1"
              autofocus
            >
              {{- 'icon-error.svg' | inline_asset_content -}}
              <span>Please check the required fields and try again.</span>
            </div>
          {%- endif -%}

          <div class="request-quote-form__summary">
            <p class="request-quote-form__label">Selected items</p>
            <pre
              class="request-quote-form__summary-box"
              id="RequestQuoteSummary"
            ></pre>
          </div>

          <div class="request-quote-form__grid">
            <input
              type="text"
              name="contact[name]"
              class="request-quote-form__input"
              autocomplete="name"
              placeholder="Your name"
              value="{% if customer %}{{ customer.name }}{% endif %}"
            >

            <input
              type="email"
              name="contact[email]"
              class="request-quote-form__input"
              autocomplete="email"
              placeholder="Business email"
              value="{% if customer %}{{ customer.email }}{% endif %}"
              required
            >

            <input
              type="tel"
              name="contact[phone]"
              class="request-quote-form__input"
              autocomplete="tel"
              placeholder="Phone number"
              value="{% if customer %}{{ customer.phone }}{% endif %}"
            >

            <input
              type="text"
              name="contact[company]"
              class="request-quote-form__input"
              autocomplete="organization"
              placeholder="Company name"
            >
          </div>

          <textarea
            name="contact[body]"
            id="RequestQuoteBody"
            class="request-quote-form__textarea"
            rows="10"
            placeholder="Tell us your quantity, delivery city, timeline, and any custom requirements."
            required
          ></textarea>

          <button
            type="submit"
            class="button request-quote-form__submit"
          >
            Submit quote request
          </button>
        {%- endform -%}
      </div>
    </div>
  </dialog>
</request-quote-modal>

{% stylesheet %}
  .request-quote-modal {
    width: min(42rem, calc(100vw - 2rem));
    border: 0;
    padding: 0;
    border-radius: 1.5rem;
    background: rgb(var(--color-background-rgb) / 0.98);
    box-shadow: 0 24px 70px rgb(0 0 0 / 0.18);
  }

  .request-quote-modal::backdrop {
    background: rgb(0 0 0 / 0.45);
    backdrop-filter: blur(6px);
  }

  .request-quote-modal__inner {
    padding: clamp(1.1rem, 2vw, 1.5rem);
  }

  .request-quote-modal__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .request-quote-modal__eyebrow {
    margin: 0 0 0.25rem;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.6);
  }

  .request-quote-modal__title {
    margin: 0;
    font-size: clamp(1.6rem, 2vw, 2rem);
  }

  .request-quote-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .request-quote-form__summary {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .request-quote-form__label {
    margin: 0;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .request-quote-form__summary-box {
    margin: 0;
    white-space: pre-wrap;
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.12);
    border-radius: 1rem;
    background: rgb(var(--color-background-rgb) / 0.7);
    padding: 0.95rem 1rem;
    min-height: 5.5rem;
    font-family: inherit;
    font-size: 0.98rem;
    line-height: 1.55;
  }

  .request-quote-form__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .request-quote-form__input,
  .request-quote-form__textarea {
    width: 100%;
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.14);
    border-radius: 1rem;
    background: rgb(var(--color-background-rgb) / 0.95);
    color: var(--color-input-text);
    padding: 0.95rem 1rem;
    font: inherit;
  }

  .request-quote-form__textarea {
    min-height: 11rem;
    resize: vertical;
  }

  .request-quote-form__submit {
    width: 100%;
    border-radius: 999px;
  }

  .request-quote-form__success,
  .request-quote-form__error {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.9rem 1rem;
    border-radius: 1rem;
  }

  .request-quote-form__success {
    background: rgb(59 130 94 / 0.1);
  }

  .request-quote-form__error {
    background: rgb(198 40 40 / 0.08);
  }

  @media screen and (max-width: 749px) {
    .request-quote-form__grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}
