

<script
  src="{{ 'results-list.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{% javascript %}
  const url = new URL(window.location.href);
  if (url.hash) {
    document.addEventListener(
      'DOMContentLoaded',
      () => {
        const card = document.getElementById(url.hash.slice(1));
        if (card) {
          card.scrollIntoView({ behavior: 'instant' });
        }
      },
      { once: true }
    );
  }
{% endjavascript %}

{% comment %} We always render this full-width, as the child blocks have width: page/full settings {% endcomment %}
<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<results-list
  class="section product-grid-container color-{{ section.settings.color_scheme }}"
  style="--padding-block-start: {{ section.settings.padding-block-start }}px; --padding-block-end: {{ section.settings.padding-block-end }}px;"
  section-id="{{ section.id }}"
  infinite-scroll="{{ section.settings.enable_infinite_scroll }}"
>
  {% render 'skip-to-content-link', href: '#ResultsList', text: 'accessibility.skip_to_results_list' %}

  <div
    class="collection-wrapper grid gap-style{% if section.settings.product_grid_width == 'full-width' %} collection-wrapper--grid-full-width{% endif %}"
  >
    {% content_for 'block',
      type: 'filters',
      id: 'filters',
      results: collection,
      results_size: collection.products_count
    %}

    {% assign products_per_page = 24 %}

    {% if section.settings.enable_infinite_scroll == false %}
      {% assign products_per_page = section.settings.products_per_page %}
    {% endif %}

    {% paginate collection.products by products_per_page %}
      {% capture children %}
        {% for product in collection.products %}
          <li
            id="{{ section.id }}-{{ product.id }}"
            class="product-grid__item product-grid__item--{{ forloop.index0 }}"
            data-page="{{ paginate.current_page }}"
            data-product-id="{{ product.id }}"
            ref="cards[]"
          >
            {% # theme-check-disable %}
            {% content_for 'block', type: '_product-card', id: 'product-card', closest.product: product %}
            {% # theme-check-enable %}
          </li>
        {% endfor %}
      {% endcapture %}

      {% render 'product-grid',
        section: section,
        children: children,
        products: collection.products,
        paginate: paginate,
        enable_infinite_scroll: section.settings.enable_infinite_scroll
      %}
    {% endpaginate %}
  </div>
</results-list>

{% stylesheet %}
  /* ── Entry animation for cards ── */
  @keyframes cardFadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Shimmer skeleton loader ── */
  @keyframes shimmer {
    0%   { background-position: -400px 0; }
    100% { background-position: 400px 0; }
  }

  /* ── Pulse ring on add-to-cart ── */
  @keyframes pulseRing {
    0%   { box-shadow: 0 0 0 0 rgba(45, 90, 27, 0.4); }
    70%  { box-shadow: 0 0 0 10px rgba(45, 90, 27, 0); }
    100% { box-shadow: 0 0 0 0 rgba(45, 90, 27, 0); }
  }

  .product-grid-container {
    background:
      radial-gradient(circle at top left, rgb(241 249 239) 0, rgb(241 249 239 / 0.92) 18%, transparent 42%),
      linear-gradient(180deg, rgb(252 251 247) 0%, rgb(255 255 255) 22%, rgb(248 250 245) 100%);
  }

  .product-grid-container .collection-wrapper {
    row-gap: 1.5rem;
  }

  .product-grid-container .facets-controls-wrapper,
  .product-grid-container .facets-mobile-wrapper {
    margin-bottom: 0.5rem;
  }

  .product-grid-container .facets--horizontal {
    padding: 1rem 1.25rem;
    border: 1px solid rgb(var(--color-border-rgb) / 0.12);
    background: rgb(255 255 255 / 0.82);
    box-shadow: 0 14px 35px rgb(41 58 31 / 0.06);
    backdrop-filter: blur(14px);
  }

  .product-grid-container .facets__summary,
  .product-grid-container .sorting-filter__select-wrapper,
  .product-grid-container .facets-toggle {
    border-radius: 999px;
  }

  .product-grid-container .facets__summary,
  .product-grid-container .sorting-filter__select-wrapper {
    min-height: 2.75rem;
    padding-inline: 0.95rem;
    border: 1px solid rgb(var(--color-border-rgb) / 0.14);
    background: rgb(255 255 255 / 0.92);
    transition: background-color 180ms ease, border-color 180ms ease, transform 180ms ease;
  }

  .product-grid-container .facets__summary:hover,
  .product-grid-container .sorting-filter__select-wrapper:hover {
    background: rgb(248 252 244);
    border-color: rgb(var(--color-foreground-rgb) / 0.18);
    transform: translateY(-1px);
  }

  .product-grid-container .product-grid {
    gap: clamp(1rem, 1.8vw, 1.5rem);
  }

  .product-grid-container .product-grid__item {
    border: 0;
    background: transparent;
    /* Staggered entry animation */
    animation: cardFadeUp 0.5s ease both;
  }

  /* Stagger each card by index (supports up to 12 visible) */
  .product-grid-container .product-grid__item--0  { animation-delay: 0ms; }
  .product-grid-container .product-grid__item--1  { animation-delay: 60ms; }
  .product-grid-container .product-grid__item--2  { animation-delay: 120ms; }
  .product-grid-container .product-grid__item--3  { animation-delay: 180ms; }
  .product-grid-container .product-grid__item--4  { animation-delay: 240ms; }
  .product-grid-container .product-grid__item--5  { animation-delay: 300ms; }
  .product-grid-container .product-grid__item--6  { animation-delay: 360ms; }
  .product-grid-container .product-grid__item--7  { animation-delay: 420ms; }
  .product-grid-container .product-grid__item--8  { animation-delay: 480ms; }
  .product-grid-container .product-grid__item--9  { animation-delay: 540ms; }
  .product-grid-container .product-grid__item--10 { animation-delay: 600ms; }
  .product-grid-container .product-grid__item--11 { animation-delay: 660ms; }

  .product-grid-container .product-grid__item .product-card {
    height: 100%;
    transition: transform 260ms cubic-bezier(0.22, 0.68, 0, 1.2), box-shadow 260ms ease;
  }

  .product-grid-container .product-grid__item .product-card__content {
    height: 100%;
    border-radius: 0;
    border: 1px solid rgb(var(--color-border-rgb) / 0.12);
    background: linear-gradient(180deg, rgb(255 255 255) 0%, rgb(252 252 248) 100%);
    box-shadow: 0 6px 20px rgb(32 41 24 / 0.07);
    overflow: hidden;
    transition: box-shadow 260ms ease, border-color 260ms ease;
  }

  /* Lift + slight scale on hover */
  .product-grid-container .product-grid__item .product-card:hover {
    transform: translateY(-8px) scale(1.015);
  }

  .product-grid-container .product-grid__item .product-card:hover .product-card__content {
    box-shadow: 0 24px 52px rgb(32 41 24 / 0.14);
    border-color: rgb(var(--color-border-rgb) / 0.22);
  }

  /* Image zoom on hover */
  .product-grid-container .product-grid__item .card-gallery,
  .product-grid-container .product-grid__item .product-card__image,
  .product-grid-container .product-grid__item slideshow-component {
    background: linear-gradient(180deg, rgb(247 249 242) 0%, rgb(255 255 255) 100%);
    padding: 1.4rem;
    overflow: hidden;
  }

  .product-grid-container .product-grid__item .card-gallery img,
  .product-grid-container .product-grid__item .product-card__image img {
    transition: transform 380ms cubic-bezier(0.22, 0.68, 0, 1.1);
  }

  .product-grid-container .product-grid__item .product-card:hover .card-gallery img,
  .product-grid-container .product-grid__item .product-card:hover .product-card__image img {
    transform: scale(1.08);
  }

  /* Subtle overlay tint on image hover */
  .product-grid-container .product-grid__item .card-gallery::after,
  .product-grid-container .product-grid__item .product-card__image::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(30, 50, 20, 0);
    transition: background 260ms ease;
    pointer-events: none;
  }

  .product-grid-container .product-grid__item .product-card:hover .card-gallery::after,
  .product-grid-container .product-grid__item .product-card:hover .product-card__image::after {
    background: rgba(30, 50, 20, 0.04);
  }

  .product-grid-container .product-grid__item .group-block {
    gap: 0.4rem;
  }

  .product-grid-container .product-grid__item .group-block-content {
    gap: 0.45rem;
  }

  .product-grid-container .product-grid__item .product-title,
  .product-grid-container .product-grid__item h3,
  .product-grid-container .product-grid__item h4 {
    font-weight: 700;
    line-height: 1.35;
    transition: color 180ms ease;
  }

  .product-grid-container .product-grid__item .product-card:hover .product-title,
  .product-grid-container .product-grid__item .product-card:hover h3,
  .product-grid-container .product-grid__item .product-card:hover h4 {
    color: rgb(30 70 15);
  }

  .product-grid-container .product-grid__item product-price,
  .product-grid-container .product-grid__item .price {
    font-weight: 700;
    color: rgb(23 43 17);
  }

  /* Add-to-cart button: slide up & pulse on hover */
  .product-grid-container .product-grid__item .quick-add__button,
  .product-grid-container .product-grid__item .add-to-cart-button {
    box-shadow: 0 10px 18px rgb(31 46 20 / 0.1);
    transform: translateY(6px);
    opacity: 0;
    transition: transform 240ms cubic-bezier(0.22, 0.68, 0, 1.1),
                opacity 240ms ease,
                background-color 180ms ease,
                box-shadow 180ms ease;
  }

  .product-grid-container .product-grid__item .product-card:hover .quick-add__button,
  .product-grid-container .product-grid__item .product-card:hover .add-to-cart-button {
    transform: translateY(0);
    opacity: 1;
  }

  .product-grid-container .product-grid__item .quick-add__button:hover,
  .product-grid-container .product-grid__item .add-to-cart-button:hover {
    animation: pulseRing 0.6s ease-out;
  }

  .product-grid-container .product-grid__item .quick-add__button:active,
  .product-grid-container .product-grid__item .add-to-cart-button:active {
    transform: scale(0.97);
  }

  /* ── Mobile ── */
  @media screen and (max-width: 749px) {
    .product-grid-container .facets--horizontal {
      padding: 0.8rem 0.9rem;
      border-radius: 0;
    }

    .product-grid-container .product-grid {
      gap: 0.9rem;
    }

    .product-grid-container .product-grid__item .card-gallery,
    .product-grid-container .product-grid__item .product-card__image,
    .product-grid-container .product-grid__item slideshow-component {
      padding: 1rem;
    }

    /* Reduce motion on mobile for performance */
    .product-grid-container .product-grid__item .product-card:hover {
      transform: translateY(-4px) scale(1.008);
    }
  }

  /* ── Respect reduced-motion preference ── */
  @media (prefers-reduced-motion: reduce) {
    .product-grid-container .product-grid__item,
    .product-grid-container .product-grid__item .product-card,
    .product-grid-container .product-grid__item .card-gallery img,
    .product-grid-container .product-grid__item .product-card__image img,
    .product-grid-container .product-grid__item .quick-add__button,
    .product-grid-container .product-grid__item .add-to-cart-button {
      animation: none;
      transition: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.collection_container",
  "enabled_on": {
    "templates": ["collection"]
  },
  "settings": [
    {
      "type": "select",
      "id": "layout_type",
      "label": "t:settings.type",
      "options": [
        {
          "value": "grid",
          "label": "t:options.grid"
        },
        {
          "value": "organic",
          "label": "t:options.editorial"
        }
      ],
      "default": "grid"
    },
    {
      "type": "select",
      "id": "product_card_size",
      "label": "t:settings.card_size",
      "options": [
        {
          "value": "small",
          "label": "t:options.small"
        },
        {
          "value": "medium",
          "label": "t:options.medium"
        },
        {
          "value": "large",
          "label": "t:options.large"
        },
        {
          "value": "extra-large",
          "label": "t:options.extra_large"
        }
      ],
      "default": "medium",
      "visible_if": "{{ section.settings.layout_type == 'grid' }}"
    },
    {
      "type": "select",
      "id": "mobile_product_card_size",
      "label": "t:settings.mobile_card_size",
      "options": [
        {
          "value": "small",
          "label": "t:options.small"
        },
        {
          "value": "large",
          "label": "t:options.large"
        }
      ],
      "default": "small"
    },
    {
      "type": "checkbox",
      "id": "enable_infinite_scroll",
      "label": "t:settings.auto_load_products",
      "default": true
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "t:settings.products_per_page",
      "min": 8,
      "max": 36,
      "step": 4,
      "default": 24,
      "visible_if": "{{ section.settings.enable_infinite_scroll == false }}"
    },
    {
      "type": "header",
      "content": "t:content.layout"
    },
    {
      "type": "select",
      "id": "product_grid_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "centered",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "centered"
    },
    {
      "type": "checkbox",
      "id": "full_width_on_mobile",
      "label": "t:settings.full_width_on_mobile",
      "default": true,
      "visible_if": "{{ section.settings.product_grid_width != 'full-width' }}"
    },
    {
      "type": "range",
      "id": "columns_gap_horizontal",
      "label": "t:settings.horizontal_gap",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "columns_gap_vertical",
      "label": "t:settings.vertical_gap",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left_padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right_padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.section_layout"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top_padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom_padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8
    }
  ],
  "presets": []
}
{% endschema %}
