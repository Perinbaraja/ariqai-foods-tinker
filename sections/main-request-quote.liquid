{{ 'page-request-quote.css' | asset_url | stylesheet_tag }}
<script src="{{ 'page-request-quote.js' | asset_url }}" defer="defer"></script>

<div class="page-width">
  <div class="request-quote-page__header">
    <h1 class="request-quote-page__title">{{ page.title }}</h1>
    {%- if page.content != blank -%}
      <div class="request-quote-page__content rte">
        {{ page.content }}
      </div>
    {%- endif -%}
  </div>

  <div class="request-quote-page__grid">
    
    {%- comment -%} Left Column: Form {%- endcomment -%}
    <div class="request-quote-page__form-column">
      {%- form 'contact', id: 'RequestQuoteForm', class: 'request-quote-page__form' -%}
        <input type="hidden" name="contact[Quote Products]" id="RequestQuoteHiddenProducts" value="">
        <input type="hidden" name="contact[Quote Source]" value="Cart/Request Quote Page">

        <div class="request-quote-page__success" role="alert" tabindex="-1" autofocus style="{% if form.posted_successfully? %}display:flex;{% else %}display:none;{% endif %}">
          <span class="svg-wrapper">
            {{- 'icon-checkmark.svg' | inline_asset_content -}}
          </span>
          <span>Your quote request has been sent successfully. We will get back to you shortly!</span>
        </div>

        <div class="request-quote-page__error" role="alert" tabindex="-1" autofocus style="{% if form.errors %}display:flex;{% else %}display:none;{% endif %}">
          <span class="svg-wrapper">
            {{- 'icon-error.svg' | inline_asset_content -}}
          </span>
          <span>Please check the required fields and try again.</span>
        </div>

        <div class="request-quote-page__fields">
          <div class="field">
            <label class="field__label" for="RequestQuoteForm-name">Full Name <span aria-hidden="true">*</span></label>
            <input class="field__input" autocomplete="name" type="text" id="RequestQuoteForm-name" name="contact[Name]" value="{% if customer %}{{ customer.name }}{% endif %}" required>
          </div>

          <div class="field">
            <label class="field__label" for="RequestQuoteForm-email">Email Address <span aria-hidden="true">*</span></label>
            <input class="field__input" autocomplete="email" type="email" id="RequestQuoteForm-email" name="contact[Email]" spellcheck="false" autocapitalize="off" value="{% if customer %}{{ customer.email }}{% endif %}" aria-required="true" required>
          </div>

          <div class="field">
            <label class="field__label" for="RequestQuoteForm-phone">Phone Number <span aria-hidden="true">*</span></label>
            <input class="field__input" autocomplete="tel" type="tel" id="RequestQuoteForm-phone" name="contact[Phone]" value="{% if customer %}{{ customer.phone }}{% endif %}" pattern="[0-9\-]*" required>
          </div>

          <div class="field">
            <label class="field__label" for="RequestQuoteForm-company">Company Name</label>
            <input class="field__input" autocomplete="organization" type="text" id="RequestQuoteForm-company" name="contact[Company]">
          </div>
        </div>

        <div class="field">
          <label class="field__label" for="RequestQuoteForm-body">Additional Requirements</label>
          <textarea rows="6" id="RequestQuoteForm-body" class="text-area field__input" name="contact[Notes]" placeholder="Tell us your requirements..."></textarea>
        </div>
        
        {%- comment -%} Standard contact body acts as a catch-all in Shopify emails {%- endcomment -%}
        <textarea rows="1" name="contact[body]" id="RequestQuoteForm-ContactBody" class="hidden" style="display:none;"></textarea>

        <div class="request-quote-page__submit-wrapper">
          <button type="submit" class="button request-quote-page__submit">
            Submit Quote Request
          </button>
        </div>
      {%- endform -%}
    </div>

    {%- comment -%} Right Column: Cart Products Summary {%- endcomment -%}
    <div class="request-quote-page__cart-column">
      <div class="request-quote-page__cart-summary">
        <h2 class="request-quote-page__cart-title">Products In Your Quote</h2>
        <div id="RequestQuoteCartContainer" class="request-quote-page__cart-items">
          <p class="request-quote-page__loading">Loading your cart items...</p>
        </div>
      </div>
    </div>
    
  </div>
</div>

{% schema %}
{
  "name": "Request Quote",
  "tag": "section",
  "class": "section",
  "settings": [
    
  ]
}
{% endschema %}
